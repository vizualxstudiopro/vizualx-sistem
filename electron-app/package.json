{
  "name": "vizualx-panel-desktop",
  "version": "1.0.0",
  "description": "VizualX Admin Panel — Aplikacioni Desktop",
  "productName": "VizualX Panel",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && electron-builder --win --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "author": "VizualX <info@vizualx.online>",
  "license": "ISC",
  "devDependencies": {
    "electron": "^29.4.5",
    "electron-builder": "^24.13.3",
    "sharp": "^0.33.4"
  }
}
